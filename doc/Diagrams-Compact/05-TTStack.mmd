%% TT-Stack Observability Architecture - Compact
flowchart LR
    subgraph App["Sally Application"]
        Svc["Services"]
        Tel["TelemetryManager"]
    end

    subgraph Collector["OTEL Collector"]
        Recv["Receiver :4317"]
        Proc["Processors"]
    end

    subgraph Storage["Storage Layer"]
        Prom[("Prometheus")]
        Tempo[("Tempo")]
        Loki[("Loki")]
    end

    subgraph Viz["Visualization"]
        Graf["Grafana :3000"]
    end

    Svc --> Tel
    Tel -->|OTLP gRPC| Recv
    Recv --> Proc
    Proc -->|metrics| Prom
    Proc -->|traces| Tempo
    Proc -->|logs| Loki
    Prom --> Graf
    Tempo --> Graf
    Loki --> Graf

