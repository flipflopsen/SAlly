%% Sally SCADA Orchestration Block Diagram
%% Author: Sally SCADA System Documentation
%% Purpose: High-level system architecture showing component orchestration

flowchart TB
    subgraph DataSources["Data Sources Layer"]
        direction LR
        HDF5[("HDF5 Files<br/>Time Series")]
        TimescaleDB[("TimescaleDB<br/>Persistent Storage")]
        MosaikWorld["Mosaik<br/>Co-Simulation"]
    end

    subgraph SimulationLayer["Simulation Layer"]
        direction LR
        HDF5Sim["SmartGridSimulation<br/><i>HDF5-based Simulation</i>"]
        MosaikSim["MosaikSimulation<br/><i>Co-Simulation Integration</i>"]
    end

    subgraph CoreServices["Core Services Layer (Event-Driven)"]
        direction TB

        subgraph EventBusCluster["EventBus (High-Performance)"]
            EventBus["EventBus<br/><i>Lock-free Ring Buffers<br/>5M+ events/sec</i>"]
            BufferPool["Buffer Pool<br/><i>SPSC/MPSC/SPMC/MPMC</i>"]
        end

        subgraph ServicesCluster["Domain Services"]
            direction LR
            RuleManager["SmartGridRuleManager<br/><i>Rule Evaluation Engine</i>"]
            SetpointService["SetpointService<br/><i>Setpoint Management</i>"]
            StabilityService["StabilityMonitoringService<br/><i>Grid Stability</i>"]
            LoadForecast["LoadForecastingService<br/><i>Prediction Engine</i>"]
        end
    end

    subgraph OrchestrationLayer["Orchestration Layer"]
        Orchestrator["SCADAOrchestrationService<br/><i>Central Coordinator</i>"]
        StateQueue["State Queue<br/><i>Thread-safe GUI updates</i>"]
        CommandQueue["Command Queue<br/><i>GUI → Simulation</i>"]
        SCADAState["SCADAState<br/><i>Consolidated State</i>"]
    end

    subgraph BridgeLayer["Communication Bridge Layer"]
        direction LR
        MQTTBridge["MqttBridgeService<br/><i>MQTT Protocol</i>"]
        WSBridge["WebSocketBridgeService<br/><i>Socket.IO</i>"]
        MQTTBroker[("Mosquitto<br/>MQTT Broker")]
    end

    subgraph PresentationLayer["Presentation Layer (GUI)"]
        direction TB

        subgraph DesktopGUI["Desktop GUI (Tkinter/ttkbootstrap)"]
            direction LR
            SCADAGUI["SCADA Main Window<br/><i>Monitoring & Control</i>"]
            SLDDisplay["SLD Display<br/><i>Single Line Diagram</i>"]
            RuleManagerGUI["Rule Manager<br/><i>Rule Configuration</i>"]
            SetpointPanel["Setpoint Panel<br/><i>Override Controls</i>"]
        end

        subgraph WebGUI["Web GUI (Angular)"]
            direction LR
            WebFrontend["SCADA Web Frontend<br/><i>Browser-based UI</i>"]
            WebBackend["Node.js Backend<br/><i>MQTT/WebSocket Gateway</i>"]
        end
    end

    subgraph TelemetryLayer["Observability Layer"]
        direction LR
        TelemetryMgr["TelemetryManager<br/><i>OTEL Integration</i>"]

        subgraph TelemetryExport["Export Targets"]
            Traces["Traces<br/><i>Tempo</i>"]
            Metrics["Metrics<br/><i>Prometheus</i>"]
            Logs["Logs<br/><i>Loki</i>"]
        end
    end

    %% Data Source Connections
    HDF5 --> HDF5Sim
    TimescaleDB <--> HDF5Sim
    MosaikWorld --> MosaikSim
    TimescaleDB <--> MosaikSim

    %% Simulation to EventBus
    HDF5Sim --> EventBus
    MosaikSim --> EventBus

    %% EventBus Distribution
    EventBus --> BufferPool
    BufferPool --> RuleManager
    BufferPool --> StabilityService
    BufferPool --> LoadForecast
    BufferPool --> Orchestrator

    %% Orchestration
    Orchestrator --> StateQueue
    Orchestrator --> SCADAState
    CommandQueue --> Orchestrator
    RuleManager --> Orchestrator
    SetpointService <--> Orchestrator

    %% Bridge Layer
    EventBus --> MQTTBridge
    EventBus --> WSBridge
    MQTTBridge --> MQTTBroker
    MQTTBroker --> WebBackend

    %% Presentation Layer
    StateQueue --> SCADAGUI
    SCADAGUI --> SLDDisplay
    SCADAGUI --> CommandQueue
    RuleManagerGUI --> RuleManager
    SetpointPanel --> SetpointService

    WebBackend --> WebFrontend
    WSBridge --> WebFrontend

    %% Telemetry
    EventBus --> TelemetryMgr
    Orchestrator --> TelemetryMgr
    RuleManager --> TelemetryMgr
    HDF5Sim --> TelemetryMgr
    TimescaleDB --> TelemetryMgr
    TelemetryMgr --> Traces
    TelemetryMgr --> Metrics
    TelemetryMgr --> Logs

    %% Styling
    classDef datasource fill:#dbeafe,stroke:#2563eb,stroke-width:2px,color:#1e40af
    classDef simulation fill:#dcfce7,stroke:#16a34a,stroke-width:2px,color:#166534
    classDef core fill:#fef3c7,stroke:#d97706,stroke-width:2px,color:#92400e
    classDef orchestration fill:#fce7f3,stroke:#db2777,stroke-width:2px,color:#9d174d
    classDef bridge fill:#e0e7ff,stroke:#4f46e5,stroke-width:2px,color:#3730a3
    classDef gui fill:#f0fdf4,stroke:#22c55e,stroke-width:2px,color:#15803d
    classDef telemetry fill:#ede9fe,stroke:#7c3aed,stroke-width:2px,color:#5b21b6

    class HDF5,TimescaleDB,MosaikWorld datasource
    class HDF5Sim,MosaikSim simulation
    class EventBus,BufferPool,RuleManager,SetpointService,StabilityService,LoadForecast core
    class Orchestrator,StateQueue,CommandQueue,SCADAState orchestration
    class MQTTBridge,WSBridge,MQTTBroker bridge
    class SCADAGUI,SLDDisplay,RuleManagerGUI,SetpointPanel,WebFrontend,WebBackend gui
    class TelemetryMgr,Traces,Metrics,Logs telemetry
