        TSDB[("🗄️ TimescaleDB<br/><br/><i>Persistent grid data<br/>storage & analysis</i>")]
    end

    subgraph SimSystems["Simulation Systems"]
        Mosaik["⚡ Mosaik Framework<br/><br/><i>Smart Grid<br/>Co-Simulation</i>"]

        PyPower["🔌 PyPower / PandaPower<br/><br/><i>Power Flow<br/>Calculations</i>"]
    end

    subgraph ObsSystems["Observability Stack (TT-Stack)"]
        Grafana["📊 Grafana<br/><br/><i>Dashboards &<br/>Visualization</i>"]

        OTELStack["🔭 OTEL + Prometheus<br/>+ Tempo + Loki<br/><br/><i>Metrics, Traces, Logs</i>"]
    end

    subgraph CommSystems["Communication Systems"]
        MQTT[("📡 MQTT Broker<br/><br/><i>Real-time messaging<br/>for web clients</i>")]

        WebBrowser["🌐 Web Browser<br/><br/><i>SCADA Web Frontend<br/>(Angular)</i>"]
    end

    %% Relationships
    Operator -->|"Monitors grid,<br/>applies setpoints"| Sally
    Engineer -->|"Configures & analyzes,<br/>views dashboards"| Sally

    Sally -->|"Reads time series"| HDF5
    Sally <-->|"Persists grid data,<br/>queries history"| TSDB

    Sally <-->|"Co-simulation<br/>integration"| Mosaik
    Mosaik -->|"Power flow<br/>calculations"| PyPower

    Sally -->|"Exports telemetry<br/>(OTLP)"| OTELStack
    OTELStack -->|"Visualization"| Grafana
    Engineer -->|"Reviews dashboards"| Grafana

    Sally -->|"Publishes events"| MQTT
    MQTT -->|"Real-time updates"| WebBrowser
    Operator -->|"Remote access"| WebBrowser

