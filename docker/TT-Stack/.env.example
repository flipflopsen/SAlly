# Sally TT-Stack Environment Configuration
# Copy this file to .env and adjust values as needed

# =============================================================================
# OpenTelemetry Configuration
# =============================================================================

# Enable/disable OTEL telemetry
SALLY_OTEL_ENABLED=true

# OTEL Collector endpoint (gRPC)
SALLY_OTEL_ENDPOINT=http://localhost:4317

# Telemetry mode: disabled, console, otlp_grpc, otlp_http, both
SALLY_OTEL_MODE=otlp_grpc

# Service version
SALLY_OTEL_SERVICE_VERSION=0.7.3

# Metrics export interval (milliseconds)
SALLY_OTEL_METRICS_INTERVAL_MS=10000

# Trace sampling rate (0.0 to 1.0, 1.0 = 100%)
SALLY_OTEL_SAMPLE_RATE=1.0

# =============================================================================
# Service-Specific Names (set by each service automatically)
# =============================================================================

# These are set programmatically but can be overridden:
# SALLY_OTEL_SERVICE_NAME=SAlly.Orchestrator
# SALLY_OTEL_SERVICE_NAME=SAlly.EventBus
# SALLY_OTEL_SERVICE_NAME=SAlly.Rules
# SALLY_OTEL_SERVICE_NAME=SAlly.Setpoints
# SALLY_OTEL_SERVICE_NAME=SAlly.GridData
# SALLY_OTEL_SERVICE_NAME=SAlly.LoadForecast
# SALLY_OTEL_SERVICE_NAME=SAlly.Stability

# =============================================================================
# Deployment Environment
# =============================================================================

# Deployment environment tag (development, staging, production)
SALLY_DEPLOYMENT_ENV=development

# =============================================================================
# Logging Configuration
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
SALLY_LOG_LEVEL=DEBUG

# =============================================================================
# Docker Network Configuration (for docker-compose)
# =============================================================================

# Ports (change if conflicts with other services)
OTEL_GRPC_PORT=4317
OTEL_HTTP_PORT=4318
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
TEMPO_PORT=3200
LOKI_PORT=3100
