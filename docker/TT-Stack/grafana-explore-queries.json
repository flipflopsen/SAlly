{
    "queries": [
        {
            "name": "Event Bus - Published Events Rate",
            "description": "Rate of events published per second by event type",
            "datasource": "prometheus",
            "expr": "rate(sally_eventbus_events_published_total[1m])"
        },
        {
            "name": "Event Bus - Processed Events Rate",
            "description": "Rate of events processed per second",
            "datasource": "prometheus",
            "expr": "rate(sally_eventbus_events_processed_total[1m])"
        },
        {
            "name": "Event Bus - Queue Depth",
            "description": "Current queue size",
            "datasource": "prometheus",
            "expr": "sally_eventbus_queue_size"
        },
        {
            "name": "Event Bus - Latency P99",
            "description": "99th percentile event processing latency",
            "datasource": "prometheus",
            "expr": "histogram_quantile(0.99, rate(sally_eventbus_event_latency_ms_bucket[5m]))"
        },
        {
            "name": "Event Bus - Dropped Events",
            "description": "Total dropped events over time",
            "datasource": "prometheus",
            "expr": "increase(sally_eventbus_events_dropped_total[5m])"
        },
        {
            "name": "Rules - Active Count",
            "description": "Number of active rules",
            "datasource": "prometheus",
            "expr": "sally_rules_active_count"
        },
        {
            "name": "Rules - Evaluations Rate",
            "description": "Rule evaluations per second",
            "datasource": "prometheus",
            "expr": "rate(sally_rules_evaluations_total[1m])"
        },
        {
            "name": "Rules - Triggered Rate",
            "description": "Rules triggered per second",
            "datasource": "prometheus",
            "expr": "rate(sally_rules_triggered_total[1m])"
        },
        {
            "name": "Rules - Evaluation Duration P95",
            "description": "95th percentile rule evaluation duration",
            "datasource": "prometheus",
            "expr": "histogram_quantile(0.95, rate(sally_rules_evaluation_duration_ms_bucket[5m]))"
        },
        {
            "name": "SCADA - Current Timestep",
            "description": "Current simulation timestep",
            "datasource": "prometheus",
            "expr": "sally_scada_simulation_timestep"
        },
        {
            "name": "SCADA - Step Duration P99",
            "description": "99th percentile simulation step duration",
            "datasource": "prometheus",
            "expr": "histogram_quantile(0.99, rate(sally_scada_step_duration_ms_bucket[5m]))"
        },
        {
            "name": "SCADA - Commands Rate",
            "description": "Commands processed per second by type",
            "datasource": "prometheus",
            "expr": "rate(sally_scada_commands_total[1m])"
        },
        {
            "name": "Setpoints - Active Count",
            "description": "Number of active setpoints",
            "datasource": "prometheus",
            "expr": "sally_setpoints_active_count"
        },
        {
            "name": "Setpoints - Applied Rate",
            "description": "Setpoints applied per second",
            "datasource": "prometheus",
            "expr": "rate(sally_setpoints_applied_total[1m])"
        },
        {
            "name": "Setpoints - Current Values",
            "description": "Current setpoint values by entity",
            "datasource": "prometheus",
            "expr": "sally_setpoints_value"
        },
        {
            "name": "Grid Data - Entities Monitored",
            "description": "Number of entities being monitored",
            "datasource": "prometheus",
            "expr": "sally_grid_data_entities_monitored"
        },
        {
            "name": "Grid Data - Collection Rate",
            "description": "Data points collected per second by entity type",
            "datasource": "prometheus",
            "expr": "rate(sally_grid_data_collected_total[1m])"
        },
        {
            "name": "OTEL Collector - Received Spans",
            "description": "Spans received by OTEL collector",
            "datasource": "prometheus",
            "expr": "rate(otelcol_receiver_accepted_spans[1m])"
        },
        {
            "name": "OTEL Collector - Exported Spans",
            "description": "Spans exported by OTEL collector",
            "datasource": "prometheus",
            "expr": "rate(otelcol_exporter_sent_spans[1m])"
        },
        {
            "name": "Trace - All Sally Services",
            "description": "Find traces from all Sally services",
            "datasource": "tempo",
            "expr": "{ resource.service.name =~ \"SAlly.*\" }"
        },
        {
            "name": "Trace - Slow Operations",
            "description": "Find operations taking more than 100ms",
            "datasource": "tempo",
            "expr": "{ resource.service.name =~ \"SAlly.*\" && duration > 100ms }"
        },
        {
            "name": "Trace - Errors",
            "description": "Find all error traces",
            "datasource": "tempo",
            "expr": "{ status = error }"
        },
        {
            "name": "Trace - Event Bus Publish",
            "description": "Find event publishing traces",
            "datasource": "tempo",
            "expr": "{ name = \"eventbus.publish\" }"
        },
        {
            "name": "Trace - Simulation Steps",
            "description": "Find simulation step traces",
            "datasource": "tempo",
            "expr": "{ name = \"scada.run_step\" }"
        },
        {
            "name": "Trace - Rule Evaluations",
            "description": "Find rule evaluation traces",
            "datasource": "tempo",
            "expr": "{ name = \"rules.evaluate\" }"
        },
        {
            "name": "Trace - Setpoint Applications",
            "description": "Find setpoint application traces",
            "datasource": "tempo",
            "expr": "{ name = \"setpoint.apply\" }"
        }
    ]
}
